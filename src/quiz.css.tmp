
/* Quiz Styles */
.quiz-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--bg-dark);
    color: white;
    padding: 2rem;
}

.quiz-container.flex-center {
    justify-content: center;
    align-items: center;
}

.quiz-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
    margin: 0 auto 4rem;
}

.progress-bar-container {
    flex: 1;
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    overflow: hidden;
}

.progress-bar-fill {
    height: 100%;
    background: var(--primary);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.step-indicator {
    font-size: 0.9rem;
    color: var(--text-muted);
    white-space: nowrap;
}

.quiz-content {
    max-width: 600px;
    width: 100%;
    margin: 0 auto;
}

.quiz-card {
    padding: 3rem;
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.quiz-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3rem;
    text-align: center;
}

.quiz-header h2 {
    font-size: 2rem;
    font-family: 'Merriweather', serif;
}

.quiz-header svg {
    color: var(--primary);
}

.quiz-body {
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.quiz-step-physics {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.gender-toggle-quiz {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.gender-btn {
    padding: 1rem;
    border-radius: 12px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}

.gender-btn.active {
    background: var(--primary);
    color: white;
    box-shadow: 0 4px 15px rgba(251, 81, 59, 0.3);
}

.physics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

.input-group {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
}

.input-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
}

.input-group input {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem;
    border-radius: 12px;
    color: white;
    font-size: 1.1rem;
    transition: all 0.2s;
}

.input-group input:focus {
    outline: none;
    border-color: var(--primary);
    background: rgba(255, 255, 255, 0.08);
}

.activity-options-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
}

.activity-option-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    color: white;
    font-weight: 500;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
}

.activity-option-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
}

.activity-option-card.active {
    background: rgba(251, 81, 59, 0.1);
    border-color: var(--primary);
    color: var(--primary);
}

.btn-quiz-next.premium {
    background: var(--primary-gradient);
}

.btn-quiz-next {
    background: var(--primary);
    color: white;
    border: none;
    padding: 1.2rem;
    border-radius: 16px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.2s;
    width: 100%;
}

.btn-quiz-next:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-quiz-back {
    margin-top: 1.5rem;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.9rem;
    text-decoration: underline;
    width: 100%;
}

/* Calculating State */
.premium-spinner {
    width: 80px;
    height: 80px;
    border: 4px solid rgba(255, 255, 255, 0.1);
    border-top: 4px solid var(--primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

.spinner-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
}

.spinner-icon {
    position: absolute;
    color: var(--primary);
}

.calculating-overlay {
    text-align: center;
    max-width: 400px;
}

/* Results Styles */
.results-hero {
    max-width: 800px;
    width: 100%;
    margin: 4rem auto;
    padding: 4rem;
    border-radius: 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
}

.quiz-results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    width: 100%;
    margin: 2rem 0;
}

.quiz-result-card {
    background: rgba(255, 255, 255, 0.05);
    padding: 2rem 1rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.quiz-result-card h3 {
    font-size: 2rem;
    margin-top: 0.5rem;
}

.quiz-result-card.highlight {
    border-color: rgba(16, 185, 129, 0.3);
    background: rgba(16, 185, 129, 0.05);
}

.quiz-result-card.premium {
    border-color: rgba(251, 81, 59, 0.3);
    background: rgba(251, 81, 59, 0.05);
}

.breakfast-callout {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 20px;
    font-size: 1.1rem;
}

.final-cta-box {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

@media (max-width: 768px) {
    .quiz-container { padding: 1rem; }
    .quiz-card { padding: 2rem 1.5rem; }
    .quiz-results-grid { grid-template-columns: 1fr; }
    .quiz-header h2 { font-size: 1.5rem; }
    .option-btn { padding: 1.5rem 1rem; }
}
